{
  "tableName": "ORG_POST",
  "tableType": "system",
  "description": "OA 岗位表（选岗位字段关联）",
  "primaryField": "ID",
  "joinRule": "ORG_POST.ID = {formTable}.{selectField}",
  "defaultFilter": "IS_ENABLE = 1 AND IS_DELETED = 0",
  "defaultFilterDescription": "默认只查启用、未删除的岗位",
  "fields": [
    {
      "fieldName": "ID",
      "displayName": "主键",
      "dbFinalType": "BIGINT",
      "description": "岗位唯一标识，可能为正数或负数 BIGINT，必须按字符串兼容处理"
    },
    {
      "fieldName": "NAME",
      "displayName": "岗位名称",
      "dbFinalType": "VARCHAR(500)",
      "description": "岗位名称，选岗位字段关联后取此列作为显示值"
    },
    {
      "fieldName": "CODE",
      "displayName": "岗位编码",
      "dbFinalType": "VARCHAR(500)",
      "description": "岗位编码"
    },
    {
      "fieldName": "TYPE",
      "displayName": "岗位类型",
      "dbFinalType": "INT",
      "description": "1=管理类，2=技术类，3=营销类，4=职能类"
    },
    {
      "fieldName": "IS_ENABLE",
      "displayName": "启用状态",
      "dbFinalType": "SMALLINT",
      "description": "1=启用，0=停用"
    },
    {
      "fieldName": "IS_DELETED",
      "displayName": "删除标记",
      "dbFinalType": "SMALLINT",
      "description": "1=已删除，0=未删除"
    },
    {
      "fieldName": "ORG_ACCOUNT_ID",
      "displayName": "所属单位ID",
      "dbFinalType": "BIGINT",
      "description": "所属单位 ID"
    }
  ],
  "relatedTables": [
    {
      "tableName": "ORG_MEMBER",
      "relation": "ORG_POST.ID = ORG_MEMBER.ORG_POST_ID",
      "description": "通过岗位 ID 关联人员表，查岗位下所有人员"
    }
  ]
}
