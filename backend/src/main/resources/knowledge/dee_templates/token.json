{
  "url": "http://oa-server/api/auth/token",
  "method": "POST",
  "headers": {
    "Content-Type": "application/json"
  },
  "body": {
    "appId": "oa_app_001",
    "appSecret": "your_app_secret",
    "grantType": "client_credentials"
  },
  "responseMapping": {
    "token": "$.data.accessToken",
    "expiresIn": "$.data.expiresIn"
  }
}
